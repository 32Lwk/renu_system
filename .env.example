GOOGLE_SERVICE_ACCOUNT_JSON_PATH=path/to/service-account.json
SPREADSHEET_ID=your_spreadsheet_id_here

# data_source: sheets or mockdb
DATA_SOURCE=sheets

# 管理者ログイン用（簡易実装）
ADMIN_PASSWORD_HASH=changeme-hash
SECRET_KEY=change-this-secret

# Discord OAuth (FastAPI 側)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-domain.example.com/auth/discord/callback

# OpenAI API キー（FastAPI / Bot 共通で利用可）
OPENAI_API_KEY=sk-xxxx

# Discord Bot 用（別リポジトリ / 別 .env 想定）
# DISCORD_BOT_TOKEN=your_discord_bot_token
# API_BASE_URL=https://your-domain.example.com

# GAS (mail sending)
GAS_WEBHOOK_URL=https://script.google.com/macros/s/xxxx/exec
GAS_WEBHOOK_SECRET=change-this

